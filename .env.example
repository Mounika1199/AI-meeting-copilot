# GPU — set to your available GPU indices (comma-separated), or leave empty for CPU
CUDA_VISIBLE_DEVICES=0

# Ollama — URL of your running Ollama instance
OLLAMA_URL=http://localhost:11434

# LLM model to use (must be pulled in Ollama first: ollama pull <model>)
LLM_MODEL=gemma3:12b-20k
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.95
LLM_REPEAT_PENALTY=1.1
LLM_MAX_TOKENS=1024

# Embedding and reranker models (downloaded automatically from HuggingFace)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SPACY_MODEL=en_core_web_md

# Retrieval settings
MAX_CONTEXT_CHARS=8000
RERANKER_RELEVANCE_THRESHOLD=-3.0
FACTUAL_SCORE_THRESHOLD=-5.0
TEMPORAL_TOP_K=10

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8018
